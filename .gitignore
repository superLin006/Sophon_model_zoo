# SDK、工具包、第三方库（体积大，不上传，用 .gitkeep 保留目录结构）
0_Toolkits/*
!0_Toolkits/.gitkeep
1_third_party/**/*
!1_third_party/**/.gitkeep

# 模型权重
*.pt
*.pth
*.bin
*.onnx
*.onnx.data
*.bmodel
*.npz

# 测试数据（用 .gitkeep 保留目录结构）
test_data/*
!test_data/.gitkeep
datasets/
audios/
models/*
!models/**/.gitkeep

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
dist/
build/

# Conda 环境
env/

# 日志和临时文件
*.log
*.tmp
*.cache
output/
results/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
