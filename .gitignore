# SDK、工具包、第三方库（体积大，不上传，用 .gitkeep 保留目录结构）
0_Toolkits/*
!0_Toolkits/.gitkeep
1_third_party/**/*
!1_third_party/**/.gitkeep

# 模型权重（含下载的 HuggingFace/ModelScope 原始权重目录）
*.pt
*.pth
*.bin
*.onnx
*.onnx.data
*.bmodel
*.npz
*.safetensors
QwenLLM/Qwen3-4B-AWQ/

# 测试数据（用 .gitkeep 保留目录结构）
test_data/*
!test_data/.gitkeep
datasets/
audios/
models/*
!models/**/.gitkeep

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
dist/
build/

# LLM-TPU 编译产物（二进制静态/动态库，从 sophgo 官方获取）
*.a
*.so
*.so.*

# Conda 环境
env/

# 日志和临时文件
*.log
*.tmp
*.cache
output/
results/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
